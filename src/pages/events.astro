---
import PageLayout from '@layouts/PageLayout.astro';
import SectionGallery from '@components/SectionGallery.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Events', url: '/events' },
];

const demo = [
  { src: '/images/events/01.jpg', w: 2000, h: 1335, alt: 'An event in full flow, Canary Wharf' },
  { src: '/images/events/02.jpg', w: 1600, h: 1067, alt: 'Keynote moment under stage light' },
  { src: '/images/events/03.jpg', w: 1600, h: 1143, alt: 'Gala dinner service' },
  { src: '/images/events/04.jpg', w: 1600, h: 1067, alt: 'The atmosphere of the evening' },
  { src: '/images/events/05.jpg', w: 1600, h: 1067, alt: 'A guest portrait at the event' },
  { src: '/images/events/06.jpg', w: 1600, h: 1068, alt: 'Editorial gala photograph' },
];
---
<PageLayout
  title="Editorial London Event & Gala Photography"
  description="Editorial documentary coverage for London galas, milestones and brand events. A selection of recent event work."
  keywords={['gala photographer London', 'event photographer London', 'corporate event photographer London', 'brand event photographer']}
  jsonLdType="page"
  breadcrumbs={breadcrumbs}
>
  <SectionGallery section="events" srTitle="Editorial Event Photography in London" fallback={demo} />
</PageLayout>
