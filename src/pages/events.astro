---
import PageLayout from '@layouts/PageLayout.astro';
import LeadForm from '@components/LeadForm.astro';
import WhatsAppCTA from '@components/WhatsAppCTA.astro';
import { Image } from 'astro:assets';
import { SERVICES } from '@lib/site';
import '../styles/lead-gen.css';

import hero from '../assets/uploads/projects/canary-wharf-gala/hero.jpg';
import shot01 from '../assets/uploads/projects/canary-wharf-gala/01-keynote.jpg';
import shot02 from '../assets/uploads/projects/canary-wharf-gala/02-dinner.jpg';
import shot03 from '../assets/uploads/projects/canary-wharf-gala/03-atmosphere.jpg';
import shot04 from '../assets/uploads/projects/canary-wharf-gala/04-portrait.jpg';
import plateGala from '../assets/uploads/plates/04-gala.jpg';

const service = SERVICES.find((s) => s.slug === 'events')!;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Events', url: '/events' },
];

const faqs = [
  {
    q: 'How quickly is the gallery delivered?',
    a: 'Press-select batch within forty-eight hours where required. The full hand-finished gallery within ten working days for events under eight hours.',
  },
  {
    q: 'Do you cover brand activations and corporate events?',
    a: 'Yes — same editorial eye, applied to your brand. Recent work includes private dinners, product launches and annual galas. References available on request.',
  },
  {
    q: 'Are you insured for venues?',
    a: '£5M public liability and equipment cover. Certificates sent directly to your venue or production team.',
  },
  {
    q: 'Last-minute coverage?',
    a: 'We hold a small number of dates each month for short-notice work. WhatsApp is the fastest way to check availability.',
  },
  {
    q: 'Can we license images for press or social?',
    a: 'Yes — commercial usage rights are available as an add-on. Editorial coverage with usage rights is quoted alongside the main package.',
  },
];

const testimonials = [
  {
    quote: 'Felt invisible in the room and yet captured every moment we wanted. The exact balance for a gala.',
    author: 'Helena C.',
    context: 'Canary Wharf Gala · 2025',
  },
  {
    quote: 'Hands-off to brief, exceptional in delivery. The kind of editorial set we use across the year.',
    author: 'A London creative agency',
    context: 'Brand launch · 2025',
  },
  {
    quote: 'The photos made the after-event press placements far stronger than anything we\'d had before.',
    author: 'M. Patel',
    context: 'Annual fundraiser · 2024',
  },
];
---
<PageLayout
  title="Editorial London Event & Gala Photography"
  description="Editorial documentary coverage for London galas, milestones and brand stories. Discreet, fast-delivery photography from £1,200."
  keywords={[
    'gala photographer London',
    'event photographer London',
    'corporate event photographer London',
    'brand launch photographer',
  ]}
  jsonLdType="page"
  breadcrumbs={breadcrumbs}
>
  <section class="lookbook-section">
    <div class="container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="sep">/</span><span>Events</span>
      </nav>

      <div class="section-divider">{service.eyebrow}</div>
      <h1 class="section-title">Galas, <em>Considered.</em></h1>
      <p class="section-subtitle">Editorial documentary coverage for London galas, brand stories and milestone moments. From £1,200 — bespoke options for full-day or multi-room work.</p>

      <div class="cover-ctas" style="justify-content: flex-start; margin-top: 2rem;">
        <a href="#enquire" class="btn btn-burgundy">Begin The Conversation</a>
        <WhatsAppCTA prefill={service.waPrefill} source="events-hero" variant="outline" />
        <a href="/lookbook" class="btn btn-outline">See The Lookbook</a>
      </div>

      <div style="margin-top: 4rem;">
        <Image src={hero} alt="Canary Wharf gala — keynote moment" widths={[800, 1200, 1800]} sizes="(min-width: 900px) 1200px, 100vw" loading="eager" />
      </div>
    </div>
  </section>

  <section class="lookbook-section" style="padding-top: 0;">
    <div class="container">
      <div class="section-divider">Section · Plates From Events</div>
      <h2 class="section-title">Coverage, in <em>Any Room.</em></h2>

      <div class="plate-grid" style="display:grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; margin-top: 3rem;">
        <Image src={shot01} alt="Keynote address, low light" widths={[400, 800]} sizes="(min-width: 900px) 400px, 100vw" />
        <Image src={shot02} alt="Gala dinner candid" widths={[400, 800]} sizes="(min-width: 900px) 400px, 100vw" />
        <Image src={shot03} alt="Atmosphere wide" widths={[400, 800]} sizes="(min-width: 900px) 400px, 100vw" />
        <Image src={shot04} alt="Guest portrait, on-stand" widths={[400, 800]} sizes="(min-width: 900px) 400px, 100vw" />
        <Image src={plateGala} alt="Editorial gala plate" widths={[400, 800]} sizes="(min-width: 900px) 400px, 100vw" />
      </div>

      <p style="text-align:center; margin-top: 3rem;">
        <a href="/portfolio/canary-wharf-gala" class="btn btn-outline">Open The Case Study</a>
      </p>
    </div>
  </section>

  <section class="lookbook-section" style="background: var(--cream); padding-block: 6rem;">
    <div class="container">
      <div class="section-divider">Section · In Their Words</div>
      <h2 class="section-title">Clients Who Trusted <em>The Night.</em></h2>

      <div class="lookbook" style="margin-top: 4rem;">
        {testimonials.map((t) => (
          <figure class="look" style="background: white;">
            <div class="look-tag">"</div>
            <blockquote style="font-family: 'Fraunces', serif; font-size: 1.25rem; line-height: 1.5; margin: 1rem 0;">{t.quote}</blockquote>
            <figcaption style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-soft);">
              <div>{t.author}</div>
              <div style="margin-top: 0.25rem;">{t.context}</div>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="lookbook-section">
    <div class="container">
      <div style="max-width:720px; margin: 0 auto;">
        <div class="section-divider">Section · Frequently Asked</div>
        <h2 class="section-title">Practical Notes, <em>Plainly Said.</em></h2>
        <div class="article-body" style="margin-top: 3rem;">
          {faqs.map((f) => (
            <details style="border-bottom: 1px solid var(--ink-line); padding: 1.5rem 0;">
              <summary style="cursor: pointer; font-family: 'Fraunces', serif; font-size: 1.2rem; font-weight: 500; list-style: none;">
                <span style="color: var(--burgundy); margin-right: 0.5rem;">+</span>{f.q}
              </summary>
              <p style="margin-top: 1rem; color: var(--ink-soft);">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <LeadForm
    service="events"
    eventType="gala"
    title="Tell Us About The Evening."
    subtitle="Date, room, scale, and what you'd like to remember of it. We'll come back within twenty-four hours."
  />
</PageLayout>
