---
import PageLayout from '@layouts/PageLayout.astro';
import { WHATSAPP } from '@lib/site';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Weddings', url: '/weddings' },
];

// CTA targets reuse what the rest of the site uses: the enquiry route is
// /contact (the site-wide "Enquire" destination); WhatsApp uses the same
// configured number as every other WhatsApp CTA, falling back to /contact
// if no number is set so the button is never broken.
const enquireHref = '/contact';
const whatsappHref = WHATSAPP.number ? `https://wa.me/${WHATSAPP.number}` : '/contact';

// Static wedding gallery. Photos live in /public/images/weddings — adding a
// new <figure> with its real width/height is all that's needed for a new
// photo (no imports, no per-image CSS). Mix portrait and landscape freely.
const photos = [
  { src: '/images/weddings/01.jpg', w: 2000, h: 1333, alt: "A couple's first look, Mayfair townhouse wedding" },
  { src: '/images/weddings/02.jpg', w: 1600, h: 1068, alt: 'Wedding couple portrait at golden hour' },
  { src: '/images/weddings/03.jpg', w: 1600, h: 1068, alt: 'Wedding ceremony at a Mayfair townhouse' },
  { src: '/images/weddings/04.jpg', w: 1600, h: 2000, alt: 'Editorial bridal portrait' },
  { src: '/images/weddings/05.jpg', w: 1600, h: 1026, alt: 'Wedding rings and the details of the day' },
  { src: '/images/weddings/06.jpg', w: 1600, h: 1067, alt: 'Reception celebration after dark' },
  { src: '/images/weddings/07.jpg', w: 1600, h: 1067, alt: 'A quiet wedding moment between the couple' },
];
---
<PageLayout
  title="Editorial London Wedding Photography"
  description="Editorial wedding photography for London. Discreet on the day, hand-finished after. A selection of recent weddings."
  keywords={['London wedding photographer', 'editorial wedding photography London', 'Mayfair wedding photographer', 'luxury wedding photographer London']}
  jsonLdType="page"
  breadcrumbs={breadcrumbs}
>
  <section class="gallery-band" aria-label="Selected weddings">
    <h1 class="sr-only">Editorial Wedding Photography in London</h1>
    <div class="gallery-grid">
      {photos.map((p) => (
        <figure class="gallery-item">
          <img
            src={p.src}
            alt={p.alt}
            width={p.w}
            height={p.h}
            loading="lazy"
            decoding="async"
          />
        </figure>
      ))}
    </div>

    <div class="gallery-cta">
      <a class="btn btn--primary" href={enquireHref}>
        Begin the Conversation
      </a>
      <a class="btn btn--ghost" href={whatsappHref} rel="noopener">
        WhatsApp
      </a>
    </div>
  </section>
</PageLayout>
