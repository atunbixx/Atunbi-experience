---
import Base from '@layouts/Base.astro';
import { Image } from 'astro:assets';
import { getDefaultGallery } from '@lib/manifest';

// Portrait = first image of the default gallery until a dedicated portrait is
// added (documented in README). Optimised at build like the rest.
const g = await getDefaultGallery();
const portrait = g?.photos[0];
---
<Base
  title="Contact — The Atunbi Experience"
  description="Get in touch with The Atunbi Experience."
  canonicalPath="/contact"
>
  <div class="contact">
    <div>
      {portrait && (
        <Image
          src={portrait.url}
          alt="The Atunbi Experience"
          width={portrait.width}
          height={portrait.height}
          widths={[400, 800]}
          sizes="(max-width: 720px) 100vw, 560px"
          format="webp"
          quality={82}
          loading="eager"
          decoding="async"
        />
      )}
      <p class="bio">
        Placeholder bio — replace in <code>src/pages/contact.astro</code>.
        London-based editorial and portrait photographer working with
        considered weddings, brands and publications across the UK and beyond.
      </p>
    </div>

    <form id="contact-form" method="post" action="/api/contact" novalidate>
      <div>
        <label for="name">Name</label>
        <input id="name" name="name" type="text" required autocomplete="name" />
      </div>
      <div>
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required autocomplete="email" />
      </div>
      <div>
        <label for="message">Message</label>
        <textarea id="message" name="message" required></textarea>
      </div>
      <input class="hp" type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <button type="submit">Send Message</button>
      <p class="form-msg" id="form-msg" role="status" aria-live="polite"></p>
    </form>
  </div>

  <script is:inline>
    (() => {
      const f = document.getElementById('contact-form');
      const msg = document.getElementById('form-msg');
      if (!f) return;
      f.addEventListener('submit', async (e) => {
        e.preventDefault();
        msg.textContent = 'Sending…';
        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(Object.fromEntries(new FormData(f))),
          });
          const j = await res.json().catch(() => ({}));
          if (res.ok && j.ok) { msg.textContent = 'Message sent'; f.reset(); }
          else { msg.textContent = j.error || 'Something went wrong. Please email hello@atunbi.com.'; }
        } catch {
          msg.textContent = 'Network error. Please email hello@atunbi.com.';
        }
      });
    })();
  </script>
</Base>
