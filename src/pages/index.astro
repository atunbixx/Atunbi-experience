---
import Base from '@layouts/Base.astro';
import Grid from '@components/Grid.astro';
import Lightbox from '@components/Lightbox.astro';
import { getDefaultGallery } from '@lib/manifest';

const gallery = await getDefaultGallery();
const ogImage = gallery?.photos[0]?.url;
---
<Base
  title="Classic — The Atunbi Experience"
  description="The Atunbi Experience — editorial photography portfolio."
  ogImage={ogImage}
  canonicalPath="/"
>
  {gallery ? (
    <>
      <Grid photos={gallery.photos} />
      <Lightbox />
    </>
  ) : (
    <p style="text-align:center;color:var(--text);padding:64px 0;">
      The portfolio is being prepared.
    </p>
  )}
</Base>
