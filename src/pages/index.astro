---
import PageLayout from '@layouts/PageLayout.astro';
import PlateCard from '@components/PlateCard.astro';
import CoverSlider from '@components/CoverSlider.astro';
import Lightbox from '@components/Lightbox.astro';
import { getCollection, getEntry } from 'astro:content';
import { SITE } from '@lib/site';

const platesEntry = await getEntry('plates', 'index');
const plates = platesEntry?.data.items ?? [];

const coverEntry = await getEntry('cover', 'index');
const coverSlides = coverEntry?.data.items ?? [];

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featuredPosts = allPosts.filter((p) => p.data.featured).slice(0, 3);
const recentPosts = (featuredPosts.length > 0 ? featuredPosts : allPosts).slice(0, 3);

const seo = {
  title: 'Editorial London Wedding & Event Photography',
  description:
    'The Atunbi Experience — London-based editorial photography for considered weddings, galas, corporate events and portrait sittings. Discreet coverage, hand-finished images.',
  keywords: [
    'London wedding photographer',
    'editorial photographer London',
    'gala photographer',
    'corporate event photographer',
    'Mayfair wedding photographer',
  ],
};
---
<PageLayout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  jsonLdType="home"
>
  <section class="cover">
    <div class="cover-grid">
      <div class="cover-text">
        <div class="plate">Cover Story · Plate I</div>
        <h1>This Is The <em>Experience.</em></h1>
        <p class="deck">Editorial photography for London's most considered weddings, galas and portrait sittings — captured quietly, finished by hand.</p>
        <div class="cover-byline">By Atunbi · London Studio · Est. {SITE.established}</div>
        <div class="cover-ctas">
          <a href="/contact" class="btn btn-burgundy">Let's Talk About Your Event</a>
          <a href="#plates" class="btn btn-outline">Turn The Page</a>
        </div>
      </div>
      {coverSlides.length > 0 ? (
        <CoverSlider slides={coverSlides} />
      ) : (
        <div class="cover-image placeholder">
          <span class="cover-image-caption">Plate I · Cover Frame · Mayfair, 2026</span>
        </div>
      )}
    </div>
  </section>

  <section class="editors-note">
    <div class="container">
      <div class="note-label">Editor's Note</div>
      <p class="note-body">
        <span class="drop-cap">P</span>hotographs that don't just document the day — they hold the room, the light, and the feeling for years to come. That is the standard we hold to, on every booking, without exception.
      </p>
    </div>
  </section>

  <section id="plates" class="plates-section">
    <div class="container">
      <div class="section-divider">Section · Portfolio</div>
      <h2 class="section-title">Selected <em>Plates.</em></h2>
      <p class="section-subtitle">A curated edit of recent work across weddings, corporate events, editorial portraits and galas.</p>
      <div class="plates-grid">
        {plates.map((plate) => (
          <PlateCard
            number={plate.number}
            title={plate.title}
            category={plate.category}
            href={plate.href ?? '/portfolio'}
            image={plate.image}
            alt={plate.alt}
            placeholderClass={plate.placeholderClass ?? ''}
          />
        ))}
      </div>
      <div style="text-align: center; margin-top: 4rem;">
        <a href="/portfolio" class="btn btn-outline">View Full Portfolio</a>
      </div>
    </div>
  </section>

  <section class="pull-quote">
    <div class="container">
      <div class="pull-quote-mark">"</div>
      <p>You won't notice us working on the day. That's the point.</p>
      <div class="pull-quote-attr">— A note on the Atunbi method</div>
    </div>
  </section>

  <section id="why" class="why-section">
    <div class="container">
      <div class="section-divider">Section · The Standard</div>
      <h2 class="section-title">Why Clients <em>Choose Us.</em></h2>
      <p class="section-subtitle">Four things that, taken together, make the difference between a photographer and a finished body of work.</p>
      <div class="why-grid">
        <div class="why-item"><div class="why-num">i.</div><h3>An Editorial Eye</h3><p>Every frame is composed with intent. We craft images that hold their power years after the event.</p></div>
        <div class="why-item"><div class="why-num">ii.</div><h3>Discreet Coverage</h3><p>We move quietly through your event, so the photographs feel honest rather than performed.</p></div>
        <div class="why-item"><div class="why-num">iii.</div><h3>Hand-Finished</h3><p>No bulk dumps, no AI presets. Every image is finished by hand and delivered as a curated final gallery.</p></div>
        <div class="why-item"><div class="why-num">iv.</div><h3>London-Native</h3><p>From Mayfair townhouses to East End warehouses, we know the venues, the light, and the rhythm.</p></div>
      </div>
      <div class="letters">
        <div class="letter"><div class="letter-stars">★★★★★</div><p>Atunbi captured our wedding in a way that felt like a film. Every guest commented on how present yet invisible the photographer was.</p><div class="letter-author">Olivia &amp; James</div><div class="letter-source">via AddToEvent · Mayfair Wedding</div></div>
        <div class="letter"><div class="letter-stars">★★★★★</div><p>We hired Atunbi for our annual gala. The images elevated the entire campaign that followed. Already booked for next year.</p><div class="letter-author">Sarah K., Marketing Director</div><div class="letter-source">via Bark · Canary Wharf Gala</div></div>
        <div class="letter"><div class="letter-stars">★★★★★</div><p>Refined, calm, brilliant. The portraits we received were the best we've ever had taken — full stop. Worth every pound.</p><div class="letter-author">Daniel M.</div><div class="letter-source">via AddToEvent · Family Portrait</div></div>
      </div>
    </div>
  </section>

  <section id="lookbook" class="lookbook-section">
    <div class="container">
      <div class="section-divider">Section · Lookbook</div>
      <h2 class="section-title">Considered <em>Investment.</em></h2>
      <p class="section-subtitle">Three considered routes — chosen by occasion, not by tier. Bespoke and combined options available on request.</p>
      <div class="lookbook">
        <div class="look"><div class="look-tag">N° 01</div><h3 class="look-name">The <em>Portrait</em></h3><p class="look-subtitle">Studio &amp; Editorial Sittings</p><div class="look-price-block">From £450 — half-day</div><ul><li>2-hour studio or location session</li><li>Two styled looks</li><li>20 hand-finished images</li><li>Personal use license</li><li>Delivered within 14 days</li></ul><a href="/contact" class="look-cta">Enquire</a></div>
        <div class="look featured"><div class="look-tag">N° 02</div><h3 class="look-name">The <em>Event</em></h3><p class="look-subtitle">Weddings &amp; Galas</p><div class="look-price-block">From £1,800 — full day</div><ul><li>Up to 10 hours of coverage</li><li>Pre-event consultation &amp; venue scout</li><li>300+ edited images, fully retouched</li><li>Online private gallery</li><li>Print-ready files included</li><li>Optional second photographer</li></ul><a href="/contact" class="look-cta">Enquire</a></div>
        <div class="look"><div class="look-tag">N° 03</div><h3 class="look-name">The <em>Brand</em></h3><p class="look-subtitle">Corporate &amp; Editorial</p><div class="look-price-block">From £1,200 — bespoke</div><ul><li>Brand-aligned creative direction</li><li>Headshots, lifestyle &amp; campaign work</li><li>Commercial usage rights</li><li>Web &amp; print-optimised delivery</li><li>Quarterly retainer available</li></ul><a href="/contact" class="look-cta">Enquire</a></div>
      </div>
      <div style="text-align:center; margin-top:3rem;">
        <a href="/lookbook" class="btn btn-outline">See Full Lookbook</a>
      </div>
    </div>
  </section>

  <section id="meet" class="meet-section">
    <div class="meet-grid">
      <div class="meet-portrait placeholder"></div>
      <div class="meet-content">
        <div class="feature-tag">Feature · Profile</div>
        <h2>Meet <em>Atunbi.</em></h2>
        <p class="standfirst">A decade behind the camera, a London-trained editorial eye, and a quiet obsession with the moments most people miss.</p>
        <p><span class="drop-cap">L</span>ondon-based with a decade of experience capturing the city's most considered weddings, corporate events and portrait sessions. Trained in editorial composition, drawn to natural light, and obsessed with the moments most people miss.</p>
        <p>The studio works exclusively with clients who care about how their event looks years later — not just on the day. Every project is treated as a single body of work, from venue walk-through to the final delivered gallery.</p>
        <div class="credits">
          <div class="credits-label">Notable Work</div>
          <div class="credits-list">Mayfair private weddings · Royal Society galas<br />Canary Wharf corporate campaigns · Tate Modern launches<br />Editorial portraits for FT, Time Out and Hospitality Weekly</div>
        </div>
        <div style="margin-top:1.6rem;">
          <a href="/about" class="btn btn-outline">Read More</a>
        </div>
      </div>
    </div>
  </section>

  {recentPosts.length > 0 && (
    <section class="plates-section">
      <div class="container">
        <div class="section-divider">Section · Journal</div>
        <h2 class="section-title">From The <em>Journal.</em></h2>
        <p class="section-subtitle">Field notes, behind-the-lens features and editorial reflections from recent assignments.</p>
        <div class="blog-list">
          {recentPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="blog-card">
              <div class="blog-card-image"></div>
              <div class="blog-card-meta">
                <span class="blog-card-category">{post.data.category}</span>
                <span class="blog-card-date">
                  {post.data.pubDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })}
                </span>
              </div>
              <h3 class="blog-card-title">{post.data.title}</h3>
              <p class="blog-card-deck">{post.data.description}</p>
            </a>
          ))}
        </div>
        <div style="text-align:center; margin-top:3rem;">
          <a href="/blog" class="btn btn-outline">Read The Journal</a>
        </div>
      </div>
    </section>
  )}

  <section class="featured-strip">
    <div class="featured-strip-content">
      <span class="featured-strip-label">As Booked Via</span>
      <span class="featured-strip-brand">AddToEvent</span>
      <span class="featured-strip-brand">·</span>
      <span class="featured-strip-brand">Bark.com</span>
      <span class="featured-strip-brand">·</span>
      <span class="featured-strip-brand">Direct</span>
    </div>
  </section>

  <section id="contact" class="final-cta">
    <h2>Let's Talk About <em>Your Event.</em></h2>
    <p>Tell us the date, the venue, and what you'd like to remember. We'll come back with a quiet, considered proposal within 24 hours.</p>
    <a href="/contact" class="btn btn-burgundy">Begin The Conversation</a>
  </section>

  <Lightbox />
</PageLayout>
