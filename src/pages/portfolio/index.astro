---
import PageLayout from '@layouts/PageLayout.astro';
import Lightbox from '@components/Lightbox.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);

const ROMAN = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X', 'XI', 'XII'];
const toRoman = (n: number) => ROMAN[n - 1] ?? String(n);

const categories = ['All', ...Array.from(new Set(projects.map((p) => p.data.category)))];

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Portfolio', url: '/portfolio' },
];
---
<PageLayout
  title="Portfolio — Selected London Photography Work"
  description="Selected work across London weddings, corporate galas, editorial portraits and brand campaigns. Hand-picked plates from recent assignments."
  keywords={['London wedding photography portfolio', 'editorial photographer portfolio', 'gala photographer London']}
  breadcrumbs={breadcrumbs}
>
  <section class="plates-section">
    <div class="container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="sep">/</span><span>Portfolio</span>
      </nav>

      <div class="section-divider" data-reveal>Section · Portfolio</div>
      <h1 class="section-title" data-reveal>Selected <em>Plates.</em></h1>
      <p class="section-subtitle" data-reveal>A curated edit of recent work across weddings, galas, editorial portraits and brand campaigns.</p>

      {projects.length > 0 && categories.length > 2 && (
        <div class="portfolio-filter" data-reveal role="group" aria-label="Filter by category">
          {categories.map((cat) => (
            <button
              class={`portfolio-filter-btn${cat === 'All' ? ' is-active' : ''}`}
              data-filter={cat}
              type="button"
            >{cat}</button>
          ))}
        </div>
      )}

      {projects.length === 0 ? (
        <p style="text-align:center; font-style:italic; color:var(--ink-soft);">
          Portfolio entries are being prepared. Add real projects via the <a href="/keystatic" style="color:var(--burgundy);">studio dashboard</a>.
        </p>
      ) : (
        <div class="project-grid" id="project-grid">
          {projects.map((project, i) => (
            <a
              href={`/portfolio/${project.slug}`}
              aria-label={`${project.data.title} — ${project.data.category}`}
              data-reveal
              data-category={project.data.category}
            >
              <div class="project-grid-image">
                {project.data.heroImage && project.data.heroAlt ? (
                  <Image
                    src={project.data.heroImage}
                    alt={project.data.heroAlt}
                    widths={[480, 800, 1200]}
                    sizes="(max-width: 600px) 100vw, (max-width: 1000px) 50vw, 33vw"
                    loading={i < 3 ? 'eager' : 'lazy'}
                    decoding="async"
                    formats={['avif', 'webp']}
                  />
                ) : (
                  <div style={`background: linear-gradient(${135 + i * 20}deg, var(--burgundy-deep), var(--burgundy)); aspect-ratio: ${i % 3 === 0 ? '4/5' : i % 3 === 1 ? '4/3' : '1/1'}; display:flex; align-items:center; justify-content:center;`}>
                    <span style="font-family:'Fraunces',serif; font-style:italic; font-weight:300; font-size:6rem; color:rgba(245,239,230,0.85);">A</span>
                  </div>
                )}
                <div class="project-grid-overlay" aria-hidden="true">
                  <span class="project-grid-overlay-title">{project.data.title}</span>
                  <span class="project-grid-overlay-cta">
                    View Project
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M7 7h10v10"/></svg>
                  </span>
                </div>
              </div>
              <div class="project-grid-meta">
                <div class="project-grid-meta-row">
                  <span class="project-grid-number">Plate {toRoman(i + 1)}</span>
                  <span class="project-grid-category">{project.data.category}</span>
                </div>
                <h2 class="project-grid-title">{project.data.title}</h2>
              </div>
            </a>
          ))}
        </div>
      )}

      <div style="text-align:center; margin-top:3rem;" data-reveal>
        <a href="/gallery" class="btn btn-outline">View All Photographs</a>
      </div>
    </div>
  </section>

  <Lightbox />
</PageLayout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.portfolio-filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('#project-grid > a');

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      btns.forEach((b) => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const filter = btn.dataset.filter ?? 'All';
      cards.forEach((card) => {
        const match = filter === 'All' || card.dataset.category === filter;
        card.style.display = match ? '' : 'none';
      });
    });
  });
</script>
