---
import PageLayout from '@layouts/PageLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import HeroImage from '@components/HeroImage.astro';
import Gallery from '@components/Gallery.astro';
import ProjectNav from '@components/ProjectNav.astro';
import Lightbox from '@components/Lightbox.astro';

export async function getStaticPaths() {
  const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
    (a, b) => a.data.order - b.data.order
  );
  return projects.map((project, idx) => ({
    params: { slug: project.slug },
    props: {
      project,
      prev: projects[(idx - 1 + projects.length) % projects.length]!,
      next: projects[(idx + 1) % projects.length]!,
    },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
  prev: CollectionEntry<'projects'>;
  next: CollectionEntry<'projects'>;
}

const { project, prev, next } = Astro.props;
const { Content } = await project.render();
const url = `/portfolio/${project.slug}`;
const layout = (project.data.layoutStyle ?? 'justified') as 'masonry' | 'justified';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Portfolio', url: '/portfolio' },
  { name: project.data.title, url },
];

const titleParts = project.data.title.split(' ');
const titleEm = titleParts.length > 1 ? titleParts.at(-1) : project.data.title;
const titleStart = titleParts.length > 1 ? titleParts.slice(0, -1).join(' ') : '';

const galleryImages = project.data.gallery.map((g) => ({
  src: g.src,
  cloudflareId: g.cloudflareId,
  cfWidth: g.cfWidth,
  cfHeight: g.cfHeight,
  alt: g.alt,
  caption: g.caption,
  description: g.description,
  tags: g.tags,
}));
---
<PageLayout
  title={project.data.title}
  description={project.data.description}
  type="article"
  keywords={project.data.keywords}
  image={`/og/portfolio/${project.slug}.png`}
  imageAlt={`${project.data.title} — The Atunbi Experience`}
  jsonLdType="project"
  breadcrumbs={breadcrumbs}
>
  <HeroImage
    src={project.data.heroImage}
    alt={project.data.heroAlt ?? project.data.title}
    title={titleStart || project.data.title}
    titleEm={titleStart ? titleEm : undefined}
    kicker={`${project.data.category}${project.data.venue ? ` · ${project.data.venue}` : ''}`}
    deck={project.data.description}
    scrim={(project.data.heroOverlay ?? 'dark') as 'dark' | 'light'}
  />

  <section>
    <div class="container">
      <nav class="breadcrumbs" aria-label="Breadcrumb" style="margin-top:2.4rem;">
        <a href="/">Home</a><span class="sep">/</span><a href="/portfolio">Portfolio</a><span class="sep">/</span><span>{project.data.title}</span>
      </nav>

      <article class="article" data-reveal>
        {project.data.eventDate && (
          <header style="text-align:center; margin-bottom:2.4rem; padding-bottom:1.6rem; border-bottom:1px solid var(--rule);">
            <div class="article-byline">
              <time datetime={project.data.eventDate.toISOString()}>
                {project.data.eventDate.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })}
              </time>
            </div>
          </header>
        )}

        <div class="article-body">
          <Content />
        </div>
      </article>

      {galleryImages.length > 0 && (
        <div data-reveal>
          <Gallery
            images={galleryImages}
            layout={layout}
            groupId={`project-${project.slug}`}
          />
        </div>
      )}

      <div style="text-align:center; margin: 4rem 0 6rem;" data-reveal>
        <a href="/contact" class="btn btn-burgundy">Enquire About Your Event</a>
      </div>
    </div>

    <ProjectNav prev={prev} next={next} />
  </section>

  <Lightbox />
</PageLayout>
