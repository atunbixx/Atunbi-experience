---
import PageLayout from '@layouts/PageLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await project.render();
const url = `/portfolio/${project.slug}`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Portfolio', url: '/portfolio' },
  { name: project.data.title, url },
];
---
<PageLayout
  title={project.data.title}
  description={project.data.description}
  type="article"
  keywords={project.data.keywords}
  image={`/og/portfolio/${project.slug}.png`}
  imageAlt={`${project.data.title} — The Atunbi Experience`}
  jsonLdType="project"
  breadcrumbs={breadcrumbs}
>
  <section>
    <div class="container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="sep">/</span><a href="/portfolio">Portfolio</a><span class="sep">/</span><span>{project.data.title}</span>
      </nav>

      <article class="article">
        <header class="article-header">
          <div class="article-kicker">
            {project.data.category}{project.data.venue ? ` · ${project.data.venue}` : ''}
          </div>
          <h1 class="article-title">{project.data.title}</h1>
          <p class="article-deck">{project.data.description}</p>
          {project.data.eventDate && (
            <div class="article-byline">
              <time datetime={project.data.eventDate.toISOString()}>
                {project.data.eventDate.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })}
              </time>
            </div>
          )}
        </header>

        {project.data.heroImage && project.data.heroAlt && (
          <div class="article-hero">
            <Image
              src={project.data.heroImage}
              alt={project.data.heroAlt}
              widths={[640, 960, 1280, 1600]}
              sizes="(max-width: 720px) 100vw, 720px"
              loading="eager"
              decoding="async"
              formats={['avif', 'webp']}
            />
          </div>
        )}

        <div class="article-body">
          <Content />
        </div>

        {project.data.gallery.length > 0 && (
          <div class="gallery">
            {project.data.gallery.map((g) => (
              <a href={g.src.src} target="_blank" rel="noopener">
                <Image
                  src={g.src}
                  alt={g.alt}
                  widths={[480, 800, 1200]}
                  sizes="(max-width: 768px) 100vw, 33vw"
                  loading="lazy"
                  decoding="async"
                  formats={['avif', 'webp']}
                />
              </a>
            ))}
          </div>
        )}
      </article>

      <div style="text-align:center; margin-top:3rem;">
        <a href="/contact" class="btn btn-burgundy">Enquire About Your Event</a>
      </div>
    </div>
  </section>
</PageLayout>
