---
import PageLayout from '@layouts/PageLayout.astro';
import Gallery from '@components/Gallery.astro';
import Lightbox from '@components/Lightbox.astro';
import { getCollection } from 'astro:content';
import { readManifest, itemsForSection, publicUrl } from '@lib/r2';

// Personal Work = the "personal-work" upload section (street & travel).
const manifest = await readManifest();
const galleryLayout = manifest.settings?.layout ?? 'justified';
const r2Images = itemsForSection(manifest.items, 'personal-work').map((g) => ({
  r2Url: publicUrl(g.key),
  width: g.width,
  height: g.height,
  alt: g.alt,
  caption: g.caption,
  description: g.description,
  tags: g.tags,
  project: g.project,
}));

// Fallback while the R2 archive is still empty: the local project galleries
// so the page is never blank before the first upload.
const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const projectImages = projects.flatMap((project) =>
  project.data.gallery.map((g) => ({
    src: g.src,
    alt: g.alt,
    caption: g.caption,
    description: g.description,
    tags: g.tags,
    project: project.data.title,
    projectHref: `/portfolio/${project.slug}`,
  }))
);

const allImages = r2Images.length > 0 ? r2Images : projectImages;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Personal Work', url: '/gallery' },
];
---
<PageLayout
  title="Personal Work — Street & Travel Photography"
  description="Personal work by Atunbi — street photography and travels. Unbriefed, exploratory frames made away from client commissions, across London and beyond."
  keywords={['street photography London', 'travel photography', 'personal photography project', 'documentary photographer London']}
  breadcrumbs={breadcrumbs}
>
  <section class="plates-section" style="padding-top: 4rem;">
    <div class="container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="sep">/</span><span>Personal Work</span>
      </nav>

      <div class="section-divider" data-reveal>Personal Work</div>
      <h1 class="section-title" data-reveal>Street &amp; <em>Travel.</em></h1>
      <p class="section-subtitle" data-reveal>Work made for myself — street photography and travels, away from client briefs, where I can explore freely. Click any frame to open it full-screen.</p>

      {allImages.length === 0 ? (
        <p style="text-align:center; font-style:italic; color:var(--ink-soft); margin: 4rem 0;">
          This collection is being prepared. Photographs are added via the <a href="/admin/gallery" style="color:var(--burgundy);">gallery manager</a> and appear here automatically.
        </p>
      ) : (
        <div data-reveal>
          <Gallery
            images={allImages}
            layout={galleryLayout}
            groupId="site-gallery"
            sizes="(max-width: 600px) 100vw, (max-width: 900px) 50vw, 33vw"
          />
        </div>
      )}

      <div style="text-align:center; margin-top:3rem; display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;" data-reveal>
        <a href="/portfolio" class="btn btn-outline">Browse By Project</a>
        <a href="/contact" class="btn btn-burgundy">Begin The Conversation</a>
      </div>
    </div>
  </section>

  <Lightbox />
</PageLayout>
