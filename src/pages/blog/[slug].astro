---
import PageLayout from '@layouts/PageLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { readingTime } from '@lib/reading-time';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, allPosts: posts },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
  allPosts: CollectionEntry<'blog'>[];
}

const { post, allPosts } = Astro.props;
const { Content, rawContent } = await post.render();
const minutes = readingTime(typeof rawContent === 'function' ? rawContent() : '');

const related = allPosts
  .filter((p) => p.slug !== post.slug)
  .map((p) => {
    const overlap = p.data.tags.filter((t) => post.data.tags.includes(t)).length;
    return { post: p, score: overlap + (p.data.category === post.data.category ? 1 : 0) };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map((x) => x.post);

const url = `/blog/${post.slug}`;
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Journal', url: '/blog' },
  { name: post.data.title, url },
];
---
<PageLayout
  title={post.data.title}
  description={post.data.description}
  canonical={post.data.canonical ?? url}
  type="article"
  publishedTime={post.data.pubDate.toISOString()}
  modifiedTime={post.data.updatedDate?.toISOString()}
  author={post.data.author}
  keywords={post.data.keywords}
  image={`/og/blog/${post.slug}.png`}
  imageAlt={`${post.data.title} — The Atunbi Experience`}
  jsonLdType="article"
  article={{
    title: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
    author: post.data.author,
    keywords: post.data.keywords,
    url,
  }}
  breadcrumbs={breadcrumbs}
>
  <section>
    <div class="container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="sep">/</span><a href="/blog">Journal</a><span class="sep">/</span><span>{post.data.title}</span>
      </nav>

      <article class="article">
        <header class="article-header">
          <div class="article-kicker">{post.data.category} · {minutes}</div>
          <h1 class="article-title">{post.data.title}</h1>
          <p class="article-deck">{post.data.description}</p>
          <div class="article-byline">
            By {post.data.author} ·
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' })}
            </time>
          </div>
        </header>

        {post.data.heroImage && post.data.heroAlt && (
          <div class="article-hero">
            <Image
              src={post.data.heroImage}
              alt={post.data.heroAlt}
              widths={[640, 960, 1280, 1600]}
              sizes="(max-width: 720px) 100vw, 720px"
              loading="eager"
              decoding="async"
              formats={['avif', 'webp']}
            />
          </div>
        )}

        <div class="article-body">
          <Content />
        </div>

        <footer class="article-footer">
          {post.data.tags.length > 0 && (
            <div class="article-tags">
              {post.data.tags.map((tag) => (
                <a class="article-tag" href={`/blog?tag=${encodeURIComponent(tag)}`}>#{tag}</a>
              ))}
            </div>
          )}
        </footer>
      </article>

      {related.length > 0 && (
        <div style="margin-top:5rem;">
          <div class="section-divider">Section · Continue Reading</div>
          <h2 class="section-title" style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 2.5rem;">Continue <em>Reading.</em></h2>
          <div class="blog-list">
            {related.map((p) => (
              <a href={`/blog/${p.slug}`} class="blog-card">
                <div class="blog-card-image"></div>
                <div class="blog-card-meta">
                  <span class="blog-card-category">{p.data.category}</span>
                  <span class="blog-card-date">
                    {p.data.pubDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })}
                  </span>
                </div>
                <h3 class="blog-card-title">{p.data.title}</h3>
                <p class="blog-card-deck">{p.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</PageLayout>
