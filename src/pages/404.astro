---
import PageLayout from '@layouts/PageLayout.astro';
---
<PageLayout
  title="Page Not Found"
  description="The page you were looking for doesn't exist. Try the portfolio, the journal, or get in touch."
  noindex
>
  <section class="final-cta">
    <h1>This Page <em>Wandered Off.</em></h1>
    <p>The page you were looking for has either moved or never existed. Try one of the routes below — or write to us directly.</p>
    <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-top:2rem;">
      <a href="/" class="btn btn-burgundy">Back To The Cover</a>
      <a href="/portfolio" class="btn btn-outline">Portfolio</a>
      <a href="/blog" class="btn btn-outline">Journal</a>
      <a href="/contact" class="btn btn-outline">Contact</a>
    </div>
  </section>
</PageLayout>
