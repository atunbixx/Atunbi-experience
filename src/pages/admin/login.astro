---
export const prerender = false;
import PageLayout from '@layouts/PageLayout.astro';

const next = Astro.url.searchParams.get('next') ?? '/admin/upload';
---
<PageLayout
  title="Studio Access"
  description="Private studio area for The Atunbi Experience."
  noindex={true}
>
  <section class="lookbook-section">
    <div class="container" style="max-width: 30rem;">
      <div class="section-divider">Studio · Private</div>
      <h1 class="section-title">Studio <em>Access.</em></h1>
      <form class="form" id="login-form" style="margin-top: 2.5rem;">
        <div>
          <label for="password">Password</label>
          <input id="password" name="password" type="password" required autocomplete="current-password" autofocus />
        </div>
        <input type="hidden" name="next" value={next} />
        <div>
          <button type="submit" class="btn btn-burgundy">Enter</button>
        </div>
        <div class="form-status" id="login-status" hidden></div>
      </form>
    </div>
  </section>

  <script is:inline define:vars={{ next }}>
    const form = document.getElementById('login-form');
    const status = document.getElementById('login-status');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.hidden = false;
      status.className = 'form-status';
      status.textContent = 'Checking…';
      const password = document.getElementById('password').value;
      try {
        const res = await fetch('/api/admin/login', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ password }),
        });
        const json = await res.json().catch(() => ({}));
        if (res.ok) {
          window.location.href = next;
        } else {
          status.className = 'form-status error';
          status.textContent = json.error || 'Incorrect password.';
        }
      } catch {
        status.className = 'form-status error';
        status.textContent = 'Network error. Try again.';
      }
    });
  </script>
</PageLayout>
