---
import PageLayout from '@layouts/PageLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

interface Finding {
  ruleId: string;
  level: 'error' | 'warn' | 'info';
  message: string;
  fix?: string;
}
interface PageReport {
  url: string;
  filepath: string;
  score: number;
  status: 'ok' | 'warn' | 'error';
  findings: Finding[];
}
interface FullReport {
  generatedAt: string;
  pages: PageReport[];
  totals: { ok: number; warn: number; error: number; errors: number; warnings: number; infos: number };
}

let report: FullReport | null = null;
const reportPath = path.resolve('dist', 'seo-report.json');
if (fs.existsSync(reportPath)) {
  try {
    report = JSON.parse(fs.readFileSync(reportPath, 'utf8'));
  } catch {
    report = null;
  }
}

const totals = report?.totals ?? { ok: 0, warn: 0, error: 0, errors: 0, warnings: 0, infos: 0 };
const pages = (report?.pages ?? []).slice().sort((a, b) => a.score - b.score);
const generatedAt = report ? new Date(report.generatedAt).toLocaleString('en-GB') : 'never';

const totalIssuesByRule = new Map<string, number>();
for (const p of pages) for (const f of p.findings) totalIssuesByRule.set(f.ruleId, (totalIssuesByRule.get(f.ruleId) ?? 0) + 1);
const ruleSummary = Array.from(totalIssuesByRule.entries()).sort((a, b) => b[1] - a[1]);
---
<PageLayout
  title="SEO Audit Dashboard"
  description="Internal SEO audit results. Pages, scores, and per-rule breakdown for The Atunbi Experience."
  noindex
>
  <section>
    <div class="admin-shell">
      <h1>SEO <em>Audit.</em></h1>
      <p style="color:var(--ink-soft); font-family:'Fraunces', serif; font-style:italic; margin-bottom:1.4rem;">
        Last build · {generatedAt}
      </p>

      {!report && (
        <div class="admin-card">
          <p>No audit report found at <code>dist/seo-report.json</code>.</p>
          <p>Run <code>npm run build</code> (or <code>npm run seo:check</code> after a build) to generate one.</p>
        </div>
      )}

      {report && (
        <Fragment>
          <div class="admin-stat">
            <div class="stat"><div class="stat-label">Pages</div><div class="stat-value">{pages.length}</div></div>
            <div class="stat"><div class="stat-label">OK</div><div class="stat-value" style="color:#1d6b3a;">{totals.ok}</div></div>
            <div class="stat"><div class="stat-label">Warn</div><div class="stat-value" style="color:#8a6500;">{totals.warn}</div></div>
            <div class="stat"><div class="stat-label">Error</div><div class="stat-value" style="color:#8C2438;">{totals.error}</div></div>
            <div class="stat"><div class="stat-label">Total errors</div><div class="stat-value">{totals.errors}</div></div>
            <div class="stat"><div class="stat-label">Total warnings</div><div class="stat-value">{totals.warnings}</div></div>
          </div>

          <h2>Per-page</h2>
          <table class="admin-table">
            <thead>
              <tr><th>Page</th><th>Status</th><th>Score</th><th>Errors</th><th>Warnings</th><th>Top issue</th></tr>
            </thead>
            <tbody>
              {pages.map((p) => {
                const e = p.findings.filter((f) => f.level === 'error').length;
                const w = p.findings.filter((f) => f.level === 'warn').length;
                const top = p.findings[0];
                return (
                  <tr class={p.status === 'error' ? 'row-error' : p.status === 'warn' ? 'row-warn' : ''}>
                    <td><a class="admin-link" href={p.url}>{p.url}</a></td>
                    <td><span class={`admin-status ${p.status}`}>{p.status}</span></td>
                    <td>{p.score}/100</td>
                    <td>{e}</td>
                    <td>{w}</td>
                    <td style="font-family:'Fraunces', serif; font-style:italic;">{top ? `[${top.ruleId}] ${top.message}` : '—'}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>

          <h2>Per-rule</h2>
          <table class="admin-table">
            <thead>
              <tr><th>Rule</th><th>Pages affected</th></tr>
            </thead>
            <tbody>
              {ruleSummary.map(([ruleId, count]) => (
                <tr><td>{ruleId}</td><td>{count}</td></tr>
              ))}
            </tbody>
          </table>

          <h2>Detailed findings</h2>
          {pages.filter((p) => p.findings.length > 0).map((p) => (
            <div class="admin-card">
              <h3 style="font-family:'Fraunces', serif; font-weight:400; font-size:1.2rem; margin-bottom:0.8rem;">
                <a href={p.url} class="admin-link">{p.url}</a>
                <span style="margin-left:0.6rem;" class={`admin-status ${p.status}`}>{p.status}</span>
              </h3>
              <ul style="list-style: none; padding-left: 0;">
                {p.findings.map((f) => (
                  <li style="margin-bottom:0.4rem; padding-left:1rem; border-left:3px solid var(--rule);">
                    <span class={`admin-status ${f.level === 'error' ? 'error' : f.level === 'warn' ? 'warn' : 'ok'}`}>{f.level}</span>
                    <strong style="margin-left:0.5rem;">[{f.ruleId}]</strong> {f.message}
                    {f.fix && <div style="color:var(--ink-soft); font-style:italic; margin-top:0.2rem;">→ {f.fix}</div>}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </Fragment>
      )}

      <div style="margin-top:3rem; display:flex; gap:1rem; flex-wrap:wrap;">
        <a href="/keystatic" class="btn btn-burgundy">Open CMS</a>
        <a href="/" class="btn btn-outline">Back to site</a>
      </div>
    </div>
  </section>
</PageLayout>
