---
import PageLayout from '@layouts/PageLayout.astro';
import SectionGallery from '@components/SectionGallery.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Portraits', url: '/portrait-sittings' },
];

const demo = [
  { src: '/images/portraits/01.jpg', w: 1600, h: 2000, alt: 'Editorial studio portrait' },
  { src: '/images/portraits/02.jpg', w: 1600, h: 1067, alt: 'Bridal portrait in soft window light' },
  { src: '/images/portraits/03.jpg', w: 1600, h: 1068, alt: 'A couple portrait at golden hour' },
  { src: '/images/portraits/04.jpg', w: 1600, h: 1068, alt: 'Editorial cultural portrait' },
  { src: '/images/portraits/05.jpg', w: 1600, h: 1067, alt: 'Brand portrait on location' },
  { src: '/images/portraits/06.jpg', w: 1600, h: 900, alt: 'Corporate headshot portrait' },
];
---
<PageLayout
  title="Editorial London Portrait Photography"
  description="Editorial portrait photography in London. Studio or location, hand-finished. A selection of recent portrait work."
  keywords={['portrait photographer London', 'editorial portrait London', 'headshot photographer London', 'family portrait London']}
  jsonLdType="page"
  breadcrumbs={breadcrumbs}
>
  <SectionGallery section="portraits" srTitle="Editorial Portrait Photography in London" fallback={demo} />
</PageLayout>
