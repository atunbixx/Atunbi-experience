---
import PageLayout from '@layouts/PageLayout.astro';
import LeadForm from '@components/LeadForm.astro';
import WhatsAppCTA from '@components/WhatsAppCTA.astro';
import { Image } from 'astro:assets';
import { SERVICES } from '@lib/site';
import '../styles/lead-gen.css';

import platePortrait from '../assets/uploads/plates/03-portrait.jpg';
import plateWedding from '../assets/uploads/plates/01-wedding.jpg';
import plateCorporate from '../assets/uploads/plates/02-corporate.jpg';
import plateGala from '../assets/uploads/plates/04-gala.jpg';
import plateCultural from '../assets/uploads/plates/05-cultural.jpg';
import plateBrand from '../assets/uploads/plates/06-brand.jpg';

const service = SERVICES.find((s) => s.slug === 'portrait-sittings')!;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Portrait Sittings', url: '/portrait-sittings' },
];

const faqs = [
  {
    q: 'Studio or location?',
    a: 'Both available. Our London studio for clean editorial light; or your home, a private members club, a park — wherever feels right for the sitting.',
  },
  {
    q: 'What\'s included for £450?',
    a: 'Two-hour session, two styled looks, twenty hand-finished images, personal use license, delivered within fourteen days.',
  },
  {
    q: 'Family sittings — how does it scale?',
    a: 'Pricing scales lightly with group size. Tell us numbers and ages and we will quote.',
  },
  {
    q: 'Headshots for personal branding?',
    a: 'Yes — covered under the Portrait sitting with commercial license available as an add-on. We also offer agency-style packages quoted bespoke.',
  },
  {
    q: 'Will the images feel like everyone else\'s family photos?',
    a: 'No. We approach a portrait sitting the way we approach an editorial — light, restraint, and a quiet hand. The frames are made to live on a wall, not in a folder.',
  },
];

const testimonials = [
  {
    quote: 'No "say cheese". Just our family, the way we actually look together.',
    author: 'The Patel Family',
    context: 'Hampstead Heath · Spring 2025',
  },
  {
    quote: 'Sat for thirty minutes and got a portrait my partner now keeps above the desk.',
    author: 'David L.',
    context: 'Studio sitting · Autumn 2025',
  },
  {
    quote: 'The kindest portrait session our newborn could have asked for. Calm, patient, gorgeous results.',
    author: 'Sarah & Idris',
    context: 'Newborn sitting · Winter 2025',
  },
];
---
<PageLayout
  title="Editorial London Portrait & Family Photography"
  description="Editorial portrait sittings in London. Studio or location. Two styled looks, twenty hand-finished frames. From £450."
  keywords={[
    'portrait photographer London',
    'family photographer London',
    'editorial portrait London',
    'headshot photographer London',
  ]}
  jsonLdType="page"
  breadcrumbs={breadcrumbs}
>
  <section class="lookbook-section">
    <div class="container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="sep">/</span><span>Portrait Sittings</span>
      </nav>

      <div class="section-divider">{service.eyebrow}</div>
      <h1 class="section-title">Sittings, in <em>Light.</em></h1>
      <p class="section-subtitle">Studio or location. Two styled looks. Twenty hand-finished frames. From £450.</p>

      <div class="cover-ctas" style="justify-content: flex-start; margin-top: 2rem;">
        <a href="#enquire" class="btn btn-burgundy">Begin The Conversation</a>
        <WhatsAppCTA prefill={service.waPrefill} source="portraits-hero" variant="outline" />
        <a href="/lookbook" class="btn btn-outline">See The Lookbook</a>
      </div>

      <div style="margin-top: 4rem;">
        <Image src={platePortrait} alt="Editorial portrait sitting, studio light" widths={[800, 1200, 1800]} sizes="(min-width: 900px) 1200px, 100vw" loading="eager" />
      </div>
    </div>
  </section>

  <section class="lookbook-section" style="padding-top: 0;">
    <div class="container">
      <div class="section-divider">Section · Plates From Sittings</div>
      <h2 class="section-title">Portraits, Hand <em>Finished.</em></h2>

      <div class="plate-grid" style="display:grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; margin-top: 3rem;">
        <Image src={plateWedding} alt="Bridal portrait, soft window light" widths={[400, 800]} sizes="(min-width: 900px) 400px, 100vw" />
        <Image src={plateCorporate} alt="Corporate headshot" widths={[400, 800]} sizes="(min-width: 900px) 400px, 100vw" />
        <Image src={plateBrand} alt="Brand portrait, on-location" widths={[400, 800]} sizes="(min-width: 900px) 400px, 100vw" />
        <Image src={plateGala} alt="Editorial portrait, gala setting" widths={[400, 800]} sizes="(min-width: 900px) 400px, 100vw" />
        <Image src={plateCultural} alt="Cultural portrait" widths={[400, 800]} sizes="(min-width: 900px) 400px, 100vw" />
      </div>
    </div>
  </section>

  <section class="lookbook-section" style="background: var(--cream); padding-block: 6rem;">
    <div class="container">
      <div class="section-divider">Section · In Their Words</div>
      <h2 class="section-title">Sittings That <em>Settled In.</em></h2>

      <div class="lookbook" style="margin-top: 4rem;">
        {testimonials.map((t) => (
          <figure class="look" style="background: white;">
            <div class="look-tag">"</div>
            <blockquote style="font-family: 'Fraunces', serif; font-size: 1.25rem; line-height: 1.5; margin: 1rem 0;">{t.quote}</blockquote>
            <figcaption style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-soft);">
              <div>{t.author}</div>
              <div style="margin-top: 0.25rem;">{t.context}</div>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="lookbook-section">
    <div class="container">
      <div style="max-width:720px; margin: 0 auto;">
        <div class="section-divider">Section · Frequently Asked</div>
        <h2 class="section-title">Practical Notes, <em>Plainly Said.</em></h2>
        <div class="article-body" style="margin-top: 3rem;">
          {faqs.map((f) => (
            <details style="border-bottom: 1px solid var(--ink-line); padding: 1.5rem 0;">
              <summary style="cursor: pointer; font-family: 'Fraunces', serif; font-size: 1.2rem; font-weight: 500; list-style: none;">
                <span style="color: var(--burgundy); margin-right: 0.5rem;">+</span>{f.q}
              </summary>
              <p style="margin-top: 1rem; color: var(--ink-soft);">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <LeadForm
    service="portrait-sittings"
    eventType="portrait"
    title="Tell Us About The Sitting."
    subtitle="Who, where, and when you'd like to sit. We'll come back within twenty-four hours."
  />
</PageLayout>
