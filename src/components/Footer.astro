---
import { SITE, CONTACT, SOCIAL } from '@lib/site';
const year = new Date().getFullYear();
---
<footer>
  <div class="colophon">
    <div class="colophon-brand">
      <p class="colophon-brand-title">The Atunbi <em>Experience</em></p>
      <p>{SITE.description} Available for travel across the UK and internationally.</p>
    </div>
    <div class="colophon-col">
      <p class="colophon-col-label">The Studio</p>
      <ul>
        <li><a href="/portfolio">Portfolio</a></li>
        <li><a href="/lookbook">Investment</a></li>
        <li><a href="/blog">Journal</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </div>
    <div class="colophon-col">
      <p class="colophon-col-label">Correspondence</p>
      <ul>
        <li><a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a></li>
        <li><a href={`tel:${CONTACT.phone.replace(/\s+/g, '')}`}>{CONTACT.phoneDisplay}</a></li>
        <li>{CONTACT.city}, UK</li>
      </ul>
    </div>
    <div class="colophon-col">
      <p class="colophon-col-label">Follow</p>
      <ul>
        <li><a href={SOCIAL.instagram} rel="me noopener" target="_blank">Instagram</a></li>
        <li><a href={SOCIAL.linkedin} rel="me noopener" target="_blank">LinkedIn</a></li>
        <li><a href={SOCIAL.behance} rel="me noopener" target="_blank">Behance</a></li>
      </ul>
    </div>
  </div>
  <div class="colophon-bottom">
    <span>© {year} · The Atunbi Experience · All photographs copyright</span>
    <span>{SITE.issueLabel} · Spring {year}</span>
  </div>
</footer>
