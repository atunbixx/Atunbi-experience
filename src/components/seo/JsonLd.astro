---
import { SITE, CONTACT, SOCIAL } from '@lib/site';

export interface Props {
  type?: 'home' | 'article' | 'project' | 'about' | 'contact' | 'page';
  article?: {
    title: string;
    description: string;
    image?: string;
    datePublished: string;
    dateModified?: string;
    author?: string;
    keywords?: string[];
    url: string;
  };
  breadcrumbs?: Array<{ name: string; url: string }>;
}

const { type = 'page', article, breadcrumbs } = Astro.props;
const siteUrl = (Astro.site ?? new URL(SITE.url)).toString().replace(/\/$/, '');

const sameAs = [SOCIAL.instagram, SOCIAL.linkedin, SOCIAL.behance].filter(Boolean);

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ProfessionalService'],
  '@id': `${siteUrl}#business`,
  name: SITE.name,
  alternateName: SITE.shortName,
  description: SITE.description,
  url: siteUrl,
  email: CONTACT.email,
  telephone: CONTACT.phone,
  image: `${siteUrl}/og/default.png`,
  logo: `${siteUrl}/og/default.png`,
  priceRange: '££–£££',
  foundingDate: String(SITE.established),
  areaServed: [
    { '@type': 'City', name: 'London' },
    { '@type': 'Country', name: 'United Kingdom' },
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: CONTACT.city,
    addressRegion: CONTACT.region,
    addressCountry: CONTACT.country,
    ...(CONTACT.postalCode ? { postalCode: CONTACT.postalCode } : {}),
    ...(CONTACT.street ? { streetAddress: CONTACT.street } : {}),
  },
  sameAs,
  knowsAbout: [
    'Wedding photography',
    'Editorial portrait photography',
    'Corporate event photography',
    'Brand campaign photography',
  ],
};

const photographerPerson = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${siteUrl}#atunbi`,
  name: 'Atunbi',
  jobTitle: 'Editorial Photographer',
  worksFor: { '@id': `${siteUrl}#business` },
  url: `${siteUrl}/about`,
  sameAs,
};

const articleData = article && {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.description,
  image: article.image ? new URL(article.image, siteUrl).toString() : `${siteUrl}/og/default.png`,
  datePublished: article.datePublished,
  dateModified: article.dateModified ?? article.datePublished,
  author: { '@type': 'Person', name: article.author ?? 'Atunbi' },
  publisher: { '@id': `${siteUrl}#business` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(article.url, siteUrl).toString() },
  ...(article.keywords && article.keywords.length > 0 ? { keywords: article.keywords.join(', ') } : {}),
};

const breadcrumbList = breadcrumbs && breadcrumbs.length > 0 && {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.name,
    item: new URL(crumb.url, siteUrl).toString(),
  })),
};

const blocks: object[] = [localBusiness];
if (type === 'about') blocks.push(photographerPerson);
if (type === 'article' && articleData) blocks.push(articleData);
if (breadcrumbList) blocks.push(breadcrumbList);
---
{blocks.map((block) => (
  <script type="application/ld+json" set:html={JSON.stringify(block)} />
))}
