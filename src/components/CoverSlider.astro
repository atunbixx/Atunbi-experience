---
import { Image } from 'astro:assets';

interface Slide {
  image: ImageMetadata;
  alt: string;
  caption?: string;
}

export interface Props {
  slides: Slide[];
  /** Auto-advance interval in milliseconds; 0 disables auto-play. */
  autoplayMs?: number;
}

const { slides, autoplayMs = 5500 } = Astro.props;
---
<div class="cover-slider" data-autoplay={autoplayMs}>
  <div class="cover-slider-viewport" data-embla-viewport>
    <div class="cover-slider-track">
      {slides.map((slide, i) => (
        <div class="cover-slider-slide" aria-roledescription="slide" aria-label={`${i + 1} of ${slides.length}`}>
          <Image
            src={slide.image}
            alt={slide.alt}
            widths={[640, 960, 1280, 1600, 2000]}
            sizes="(max-width: 900px) 100vw, 56vw"
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
            formats={['avif', 'webp']}
          />
          {slide.caption && <span class="cover-slider-caption">{slide.caption}</span>}
        </div>
      ))}
    </div>
  </div>

  {slides.length > 1 && (
    <Fragment>
      <button class="cover-slider-btn cover-slider-btn-prev" type="button" aria-label="Previous slide" data-embla-prev>
        <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="cover-slider-btn cover-slider-btn-next" type="button" aria-label="Next slide" data-embla-next>
        <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>

      <div class="cover-slider-dots" data-embla-dots role="tablist" aria-label="Slide navigation">
        {slides.map((_, i) => (
          <button class="cover-slider-dot" type="button" data-index={i} aria-label={`Go to slide ${i + 1}`}></button>
        ))}
      </div>

      <div class="cover-slider-counter">
        <span data-embla-current>1</span>
        <span class="cover-slider-counter-sep">/</span>
        <span>{slides.length}</span>
      </div>
    </Fragment>
  )}
</div>

<script>
  import EmblaCarousel from 'embla-carousel';

  type AutoPlayHandle = { stop: () => void; restart: () => void };

  function createAutoplay(api: ReturnType<typeof EmblaCarousel>, ms: number): AutoPlayHandle {
    let timer: ReturnType<typeof setTimeout> | null = null;
    const tick = () => {
      timer = setTimeout(() => {
        if (!document.hidden && api) {
          api.scrollNext();
        }
        tick();
      }, ms);
    };
    const stop = () => { if (timer) { clearTimeout(timer); timer = null; } };
    const restart = () => { stop(); tick(); };
    tick();
    return { stop, restart };
  }

  function init(root: HTMLElement) {
    const viewport = root.querySelector<HTMLElement>('[data-embla-viewport]');
    if (!viewport) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const autoplayMs = Number(root.dataset.autoplay ?? 0);

    const api = EmblaCarousel(viewport, {
      loop: true,
      duration: reduce ? 0 : 32,
      align: 'center',
      skipSnaps: false,
      dragFree: false,
    });

    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-embla-dots] button'));
    const current = root.querySelector<HTMLElement>('[data-embla-current]');
    const prev = root.querySelector<HTMLButtonElement>('[data-embla-prev]');
    const next = root.querySelector<HTMLButtonElement>('[data-embla-next]');

    const update = () => {
      const i = api.selectedScrollSnap();
      dots.forEach((d, idx) => d.classList.toggle('is-active', idx === i));
      if (current) current.textContent = String(i + 1);
    };
    update();
    api.on('select', update);
    api.on('reInit', update);

    dots.forEach((d, i) => d.addEventListener('click', () => api.scrollTo(i)));
    prev?.addEventListener('click', () => api.scrollPrev());
    next?.addEventListener('click', () => api.scrollNext());

    if (autoplayMs > 0 && !reduce) {
      const autoplay = createAutoplay(api, autoplayMs);
      const pauseEvents = ['mouseenter', 'focusin', 'pointerdown'];
      const resumeEvents = ['mouseleave', 'focusout'];
      pauseEvents.forEach((evt) => root.addEventListener(evt, autoplay.stop));
      resumeEvents.forEach((evt) => root.addEventListener(evt, autoplay.restart));
      api.on('pointerDown', autoplay.stop);
      api.on('pointerUp', autoplay.restart);
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) autoplay.stop(); else autoplay.restart();
      });
    }

    // Keyboard nav when slider has focus
    root.addEventListener('keydown', (e) => {
      const ke = e as KeyboardEvent;
      if (ke.key === 'ArrowLeft') { ke.preventDefault(); api.scrollPrev(); }
      if (ke.key === 'ArrowRight') { ke.preventDefault(); api.scrollNext(); }
    });
  }

  document.querySelectorAll<HTMLElement>('.cover-slider').forEach(init);
</script>
