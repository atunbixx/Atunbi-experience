---
import { NAV, NAV_CTA } from '@lib/site';

const here = Astro.url.pathname;
const isCurrent = (href: string) => {
  if (href === '/') return here === '/';
  if (href.startsWith('/#')) return false;
  return here === href || here.startsWith(href + '/');
};
---
<nav aria-label="Primary" id="site-nav">
  <ul>
    {NAV.map(({ label, href }) => (
      <li>
        <a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>{label}</a>
      </li>
    ))}
  </ul>
  <a href={NAV_CTA.href} class="nav-cta">{NAV_CTA.label}</a>
</nav>

<script>
  const nav = document.getElementById('site-nav');
  const scrollCue = document.querySelector<HTMLElement>('.scroll-cue');

  if (nav) {
    const onScroll = () => {
      const y = window.scrollY;
      nav.classList.toggle('is-scrolled', y > 60);
      if (scrollCue) scrollCue.classList.toggle('is-hidden', y > 120);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
