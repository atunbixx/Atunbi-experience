---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  prev: CollectionEntry<'projects'>;
  next: CollectionEntry<'projects'>;
}

const { prev, next } = Astro.props;

const bgFor = (project: CollectionEntry<'projects'>) =>
  project.data.heroImage
    ? `background-image:url(${project.data.heroImage.src})`
    : `background:linear-gradient(135deg, var(--burgundy-deep), var(--burgundy));`;

const splitTitle = (title: string) => {
  const parts = title.split(' ');
  if (parts.length < 2) return { start: '', em: title };
  return { start: parts.slice(0, -1).join(' '), em: parts.slice(-1)[0]! };
};

const prevTitle = splitTitle(prev.data.title);
const nextTitle = splitTitle(next.data.title);
---
<nav class="project-nav" aria-label="Other projects">
  <a class="project-nav-card prev" href={`/portfolio/${prev.slug}`}>
    <div class="project-nav-card-img" style={bgFor(prev)}></div>
    <div class="project-nav-card-content">
      <div class="project-nav-direction">← Previous Project</div>
      <h2 class="project-nav-card-title">
        {prevTitle.start && <Fragment>{prevTitle.start}{' '}</Fragment>}<em>{prevTitle.em}</em>
      </h2>
      <div class="project-nav-card-meta">
        {prev.data.category}{prev.data.venue ? ` · ${prev.data.venue}` : ''}
      </div>
    </div>
  </a>
  <a class="project-nav-card next" href={`/portfolio/${next.slug}`}>
    <div class="project-nav-card-img" style={bgFor(next)}></div>
    <div class="project-nav-card-content">
      <div class="project-nav-direction">Next Project →</div>
      <h2 class="project-nav-card-title">
        {nextTitle.start && <Fragment>{nextTitle.start}{' '}</Fragment>}<em>{nextTitle.em}</em>
      </h2>
      <div class="project-nav-card-meta">
        {next.data.category}{next.data.venue ? ` · ${next.data.venue}` : ''}
      </div>
    </div>
  </a>
</nav>
