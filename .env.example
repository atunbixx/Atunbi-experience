# Public site URL (used for canonical, sitemap, OG tags)
SITE_URL=https://www.theatunbiexperience.com

# Keystatic — required for the CMS to authenticate via the GitHub App
# Install the Keystatic GitHub App on this repo, then paste values here.
# https://keystatic.com/docs/github-app
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# Contact form (Resend transactional email + Cloudflare Turnstile spam protection)
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@atunbi.com
CONTACT_FROM_EMAIL=site@theatunbiexperience.co.uk
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: PageSpeed Insights API key for the SEO admin dashboard
PSI_API_KEY=

# --- Lead generation layer ---

# Meta Pixel (client-side) + Conversions API (server-side)
PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_TEST_EVENT_CODE=          # remove in prod

# WhatsApp Business deep-link CTAs (E.164 format, no leading +)
# e.g. PUBLIC_WHATSAPP_NUMBER=447900000000
PUBLIC_WHATSAPP_NUMBER=

# Optional: lead-side notification email (defaults to RESEND_FROM_EMAIL / CONTACT_FROM_EMAIL)
RESEND_FROM_EMAIL=

# Notion CRM — for lead capture
NOTION_API_KEY=
NOTION_LEADS_DB_ID=

# Slack — incoming webhook for lead notifications
SLACK_WEBHOOK_URL=

# --- Gallery: Cloudflare R2 storage + upload interface ---

# Public custom domain on the R2 bucket (NOT the r2.dev URL)
PUBLIC_R2_BASE=https://assets.theatunbiexperience.com

# R2 S3 API credentials — create at Cloudflare → R2 → Manage R2 API Tokens
# (Object Read & Write, scoped to the bucket). SECRET — Vercel env only.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=theatunbiexperience-assets

# Password gate for /admin/* and the upload API. SECRET.
ADMIN_PASSWORD=

# Optional: Vercel Deploy Hook — pinged after an upload so new photos go
# live without a manual redeploy. Vercel → Project → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK_URL=
