# Public site URL (used for canonical, sitemap, OG tags)
SITE_URL=https://www.theatunbiexperience.com

# Keystatic — required for the CMS to authenticate via the GitHub App
# Install the Keystatic GitHub App on this repo, then paste values here.
# https://keystatic.com/docs/github-app
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# Contact form (Resend transactional email + Cloudflare Turnstile spam protection)
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@atunbi.com
CONTACT_FROM_EMAIL=site@theatunbiexperience.co.uk
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: PageSpeed Insights API key for the SEO admin dashboard
PSI_API_KEY=
