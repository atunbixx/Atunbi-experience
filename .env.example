# Build-time
SITE_URL=https://classic.theatunbiexperience.com
# Public R2 manifest the build reads (no auth, no API). Override only if it moves.
GALLERY_MANIFEST_URL=https://assets.theatunbiexperience.com/gallery/manifest.json
# Public R2 origin images are served from.
ASSETS_BASE=https://assets.theatunbiexperience.com

# Cloudflare Pages Function: contact form (set in Pages dashboard, never commit)
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@atunbi.com

# Optional analytics — only injected if set
PLAUSIBLE_DOMAIN=
